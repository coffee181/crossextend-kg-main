{
  "description": "LLM backend configurations - copy a block into pipeline config's 'llm' section",
  "backends": {
    "deepseek": {
      "base_url": "https://api.deepseek.com",
      "api_key": "${DEEPSEEK_API_KEY}",
      "model": "deepseek-chat",
      "timeout_sec": 600,
      "max_tokens": 4096,
      "temperature": 0.1,
      "_comment": "DeepSeek API - cost-effective for large experiments"
    },
    "deepseek_reasoner": {
      "base_url": "https://api.deepseek.com",
      "api_key": "${DEEPSEEK_API_KEY}",
      "model": "deepseek-reasoner",
      "timeout_sec": 1200,
      "max_tokens": 8192,
      "temperature": 0.0,
      "_comment": "DeepSeek Reasoner - for complex reasoning tasks"
    },
    "openai_gpt4": {
      "base_url": "https://api.openai.com/v1",
      "api_key": "${OPENAI_API_KEY}",
      "model": "gpt-4o",
      "timeout_sec": 600,
      "max_tokens": 4096,
      "temperature": 0.1,
      "_comment": "OpenAI GPT-4o - high quality but expensive"
    },
    "openai_gpt35": {
      "base_url": "https://api.openai.com/v1",
      "api_key": "${OPENAI_API_KEY}",
      "model": "gpt-3.5-turbo",
      "timeout_sec": 300,
      "max_tokens": 2048,
      "temperature": 0.1,
      "_comment": "OpenAI GPT-3.5 - fast and cheap"
    },
    "local_ollama_qwen3_8b": {
      "base_url": "http://127.0.0.1:11434/v1",
      "api_key": "",
      "model": "qwen3:8b",
      "timeout_sec": 600,
      "max_tokens": 4096,
      "temperature": 0.1,
      "_comment": "Local Ollama Qwen3 8B - free but requires local GPU"
    },
    "local_ollama_deepseek32b": {
      "base_url": "http://127.0.0.1:11434/v1",
      "api_key": "",
      "model": "deepseek-r1:32b",
      "timeout_sec": 1200,
      "max_tokens": 8192,
      "temperature": 0.0,
      "_comment": "Local Ollama DeepSeek R1 32B - local reasoning model"
    },
    "minimax": {
      "base_url": "https://api.minimax.chat/v1",
      "api_key": "${MINIMAX_API_KEY}",
      "model": "abab6.5s-chat",
      "timeout_sec": 600,
      "max_tokens": 4096,
      "temperature": 0.1,
      "_comment": "MiniMax API - Chinese AI provider"
    },
    "moonshot": {
      "base_url": "https://api.moonshot.cn/v1",
      "api_key": "${MOONSHOT_API_KEY}",
      "model": "moonshot-v1-8k",
      "timeout_sec": 600,
      "max_tokens": 4096,
      "temperature": 0.1,
      "_comment": "Moonshot Kimi - Chinese AI provider"
    },
    "zhipu": {
      "base_url": "https://open.bigmodel.cn/api/paas/v4",
      "api_key": "${ZHIPU_API_KEY}",
      "model": "glm-4",
      "timeout_sec": 600,
      "max_tokens": 4096,
      "temperature": 0.1,
      "_comment": "Zhipu GLM-4 - Chinese AI provider"
    }
  },
  "default_backend": "deepseek",
  "_usage": "Copy the backend config you need into pipeline config's 'llm' section and adjust base_url/api_key/model if needed"
}
