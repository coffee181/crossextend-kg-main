{
  "description": "Embedding backend configurations - copy a block into pipeline config's 'embedding' section",
  "backends": {
    "local_ollama_bge_m3": {
      "base_url": "http://127.0.0.1:11434/v1",
      "api_key": "",
      "model": "bge-m3:latest",
      "timeout_sec": 300,
      "dimensions": 1024,
      "_comment": "Local Ollama BGE-M3 - free, high quality multilingual embedding"
    },
    "local_ollama_nomic": {
      "base_url": "http://127.0.0.1:11434/v1",
      "api_key": "",
      "model": "nomic-embed-text",
      "timeout_sec": 300,
      "dimensions": 768,
      "_comment": "Local Ollama Nomic - lightweight embedding"
    },
    "openai_text_embedding_3_small": {
      "base_url": "https://api.openai.com/v1",
      "api_key": "${OPENAI_API_KEY}",
      "model": "text-embedding-3-small",
      "timeout_sec": 60,
      "dimensions": 1536,
      "_comment": "OpenAI embedding - high quality, paid"
    },
    "openai_text_embedding_3_large": {
      "base_url": "https://api.openai.com/v1",
      "api_key": "${OPENAI_API_KEY}",
      "model": "text-embedding-3-large",
      "timeout_sec": 60,
      "dimensions": 3072,
      "_comment": "OpenAI large embedding - highest quality, expensive"
    },
    "jina": {
      "base_url": "https://api.jina.ai/v1",
      "api_key": "${JINA_API_KEY}",
      "model": "jina-embeddings-v2-base-en",
      "timeout_sec": 60,
      "dimensions": 768,
      "_comment": "Jina embeddings - specialized for search"
    }
  },
  "default_backend": "local_ollama_bge_m3",
  "_usage": "Copy the backend config you need into pipeline config's 'embedding' section and adjust base_url/api_key/model if needed"
}
