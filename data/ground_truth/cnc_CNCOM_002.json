    {
      "evidence_id": "CNCOM_002",
      "label": "T1",
      "step_id": "T1",
      "surface_form": "On Kestrel VMC-850, record whether the spindle chiller leak appears only under circulation or remains wet after shutdown, and note the exact hose branch, residue color, and cabinet-side drip path before the cover is opened.",
      "should_be_in_graph": true,
      "expected_anchor": "Task",
      "reason": "O&M step T1, leak observation recording phase"
    },
    {
      "evidence_id": "CNCOM_002",
      "label": "T2",
      "step_id": "T2",
      "surface_form": "Isolate machine power as required, expose the spindle chiller hoses, hose clamps, tube necks, and nearby cable tray, and preserve the as-found hose twist so the original side load can still be judged.",
      "should_be_in_graph": true,
      "expected_anchor": "Task",
      "reason": "O&M step T2, power isolation and component exposure phase"
    },
    {
      "evidence_id": "CNCOM_002",
      "label": "T3",
      "step_id": "T3",
      "surface_form": "Wipe only loose coolant film, then trace the wet boundary from the lowest drip point back toward the hose neck, clamp line, quick connector, or chiller manifold seam instead of assuming the largest stain is the source.",
      "should_be_in_graph": true,
      "expected_anchor": "Task",
      "reason": "O&M step T3, leak tracing phase"
    },
    {
      "evidence_id": "CNCOM_002",
      "label": "T4",
      "step_id": "T4",
      "surface_form": "Pressure-test the local cooling branch and hold long enough to see whether fresh coolant appears at the clamp gap, molded hose bend, tube bead, or manifold fitting, because tracking can blur the origin if the branch is released too early.",
      "should_be_in_graph": true,
      "expected_anchor": "Task",
      "reason": "O&M step T4, pressure test phase"
    },
    {
      "evidence_id": "CNCOM_002",
      "label": "T5",
      "step_id": "T5",
      "surface_form": "Compare clamp clocking, hose insertion depth, and bracket preload with a dry reference branch so a hose forced off-axis by the machine frame clip is not misread as a failed fitting.",
      "should_be_in_graph": true,
      "expected_anchor": "Task",
      "reason": "O&M step T5, comparison and preload analysis phase"
    },
    {
      "evidence_id": "CNCOM_002",
      "label": "T6",
      "step_id": "T6",
      "surface_form": "Close the inspection only after the report names the exact leak boundary as upper spindle-chiller hose clamp, return-hose elbow, quick connector body, or manifold fitting, with the pressure result tied to that hardware.",
      "should_be_in_graph": true,
      "expected_anchor": "Task",
      "reason": "O&M step T6, inspection closure phase"
    },
    {
      "evidence_id": "CNCOM_002",
      "label": "T7",
      "step_id": "T7",
      "surface_form": "Repeat the same speed, orientation, or clamp event after the local hardware settles so the accepted result reflects the true spindle operating condition rather than a one-time static check.",
