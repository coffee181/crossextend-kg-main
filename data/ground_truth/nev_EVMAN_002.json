    {
      "evidence_id": "EVMAN_002",
      "label": "T1",
      "step_id": "T1",
      "surface_form": "On vehicle Aurex E-Motion-412 LR, record battery coolant level, residue color, undertray wetness, recent thermal-system repair history, and whether seepage is already visible at the left coolant-plate outlet while the pack remains in the as-received condition with no covers moved.",
      "should_be_in_graph": true,
      "expected_anchor": "Task",
      "reason": "O&M step T1, intake documentation"
    },
    {
      "evidence_id": "EVMAN_002",
      "label": "T2",
      "step_id": "T2",
      "surface_form": "Power the vehicle down, isolate the high-voltage pack, and allow the local cooling branch to equalize; then remove the rear underbody shield and the left pack-side splash cover while keeping the hose angle unchanged so the original quick-coupler seating witness can still be read.",
      "should_be_in_graph": true,
      "expected_anchor": "Task",
      "reason": "O&M step T2, vehicle isolation and access"
    },
    {
      "evidence_id": "EVMAN_002",
      "label": "T3",
      "step_id": "T3",
      "surface_form": "Wipe only the loose surface film first, leave the wet edge untouched, and trace the leak path from the coolant-plate seam toward the outlet hose, the quick-coupler lock window, the O-ring seat, and the nearby bracket drain edge so the actual origin is not blurred by cleaning too early.",
      "should_be_in_graph": true,
      "expected_anchor": "Task",
      "reason": "O&M step T3, leak tracing"
    },
    {
      "evidence_id": "EVMAN_002",
      "label": "T4",
      "step_id": "T4",
      "surface_form": "Install the local pressure tool on the coolant-plate inlet and outlet, cap the neighboring branch, and hold the specified pressure long enough to observe whether fresh wetting begins at the plate seam, the coupler body, the hose clamp line, or the tube insertion stop inside the connector.",
      "should_be_in_graph": true,
      "expected_anchor": "Task",
      "reason": "O&M step T4, pressure test"
    },
    {
      "evidence_id": "EVMAN_002",
      "label": "T5",
      "step_id": "T5",
      "surface_form": "Compare the suspect joint with the opposite coolant-plate branch, paying attention to hose twist, clamp clocking, connector latch height, tube insertion depth, and any side-load mark where the support bracket may have forced the plastic coupler body off-axis.",
      "should_be_in_graph": true,
      "expected_anchor": "Task",
      "reason": "O&M step T5, cross-comparison"
    },
    {
      "evidence_id": "EVMAN_002",
      "label": "T6",
      "step_id": "T6",
      "surface_form": "Inspect the aluminum plate edge, the molded quick connector, the green O-ring land, the hose end, and the nearby harness clip for dried coolant crystals, abrasion, plastic stress whitening, or metal staining that would separate connector leakage from a plate-side crack.",
      "should_be_in_graph": true,
      "expected_anchor": "Task",
      "reason": "O&M step T6, component inspection"
    },
    {
      "evidence_id": "EVMAN_002",
      "label": "T7",
      "step_id": "T7",
      "surface_form": "Mark the confirmed leak boundary directly at the leaking hardware, photograph the coolant-plate seam and the quick-coupler seat from more than one angle, and note clearly whether the failure belongs to the plate seam, the O-ring interface, the connector shell, or the hose-routing condition.",
      "should_be_in_graph": true,
      "expected_anchor": "Task",
      "reason": "O&M step T7, boundary confirmation"
    },
    {
      "evidence_id": "EVMAN_002",
      "label": "T8",
      "step_id": "T8",
      "surface_form": "Refit only the access parts needed to protect the opened area, leave the identified leak point readable for downstream repair, and close the record with the exact hardware named as battery coolant-plate outlet quick connector or coolant-plate seam instead of leaving a generic leak description.",
      "should_be_in_graph": true,
      "expected_anchor": "Task",
      "reason": "O&M step T8, closure"
