    {
      "evidence_id": "EVMAN_003",
      "label": "T1",
      "step_id": "T1",
      "surface_form": "At Velorian PackLine-287 AWD, reproduce the service-disconnect seating complaint by noting latch feel, insertion force, handle flushness, any HVIL warning, and whether the orange handle sits proud of the battery access opening or snaps back after seating.",
      "should_be_in_graph": true,
      "expected_anchor": "Task",
      "reason": "O&M step T1, intake documentation"
    },
    {
      "evidence_id": "EVMAN_003",
      "label": "T2",
      "step_id": "T2",
      "surface_form": "Depower the pack, verify zero residual high-voltage potential at the service-disconnect cavity, and remove the access lid so the disconnect plug, blade set, guide rail, interlock pins, latch window, and surrounding sealing edge are all visible in one service view.",
      "should_be_in_graph": true,
      "expected_anchor": "Task",
      "reason": "O&M step T2, pack isolation and exposure"
    },
    {
      "evidence_id": "EVMAN_003",
      "label": "T3",
      "step_id": "T3",
      "surface_form": "Pull the service disconnect straight out without rotating it, then inspect the male blades, female socket faces, guide ribs, CPA feature, handle pivot, and latch hook for burrs, arc marks, plastic rollover, uneven insertion witness lines, or debris.",
      "should_be_in_graph": true,
      "expected_anchor": "Task",
      "reason": "O&M step T3, disconnect inspection"
    },
    {
      "evidence_id": "EVMAN_003",
      "label": "T4",
      "step_id": "T4",
      "surface_form": "Compare the suspect disconnect with a known-good reference or spare, checking seating depth, latch travel, blade exposure, guide-rib alignment, and the shoulder position of the interlock pins.",
      "should_be_in_graph": true,
      "expected_anchor": "Task",
      "reason": "O&M step T4, comparison analysis"
    },
    {
      "evidence_id": "EVMAN_003",
      "label": "T5",
      "step_id": "T5",
      "surface_form": "Rework the seat condition by correcting the misaligned guide feature, removing only the minor burr or displaced plastic that blocks full travel, and cleaning the contact area without changing the original blade profile.",
      "should_be_in_graph": true,
      "expected_anchor": "Task",
      "reason": "O&M step T5, repair action"
    },
    {
      "evidence_id": "EVMAN_003",
      "label": "T6",
      "step_id": "T6",
      "surface_form": "Reinstall the service disconnect in one continuous motion, confirm full blade entry, verify the latch hook snaps fully into the window, and check that the orange handle now remains flush with the cover plane.",
      "should_be_in_graph": true,
      "expected_anchor": "Task",
      "reason": "O&M step T6, reinstall verification"
    },
    {
      "evidence_id": "EVMAN_003",
      "label": "T7",
      "step_id": "T7",
      "surface_form": "Restore the service lid, wake the pack, and confirm through two seat checks that the HVIL path, service-disconnect status, and ready-state permissive remain stable with no handle movement, no latch relaxation, and no repeat interlock warning.",
